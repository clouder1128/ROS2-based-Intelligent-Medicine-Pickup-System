<?xml version="1.0" ?>
<sdf version="1.11">

  <model name="newthreewheelcar">

    <link name="body">
      <pose>0 0 0.35 0 0 0</pose>
      <inertial auto="true">
        <density>1000</density>
      </inertial>

      <collision name="collision1">
        <geometry>
            <box>
                <size>1.2 0.5 0.3</size>
            </box>
        </geometry>
      </collision>

      <visual name="visual1">
        <geometry>
            <box>
                <size>1.2 0.5 0.3</size>
            </box>
        </geometry>

        <material>
            <ambient>1.0 0.0 1.0 1</ambient>
            <diffuse>1.0 0.0 1.0 1</diffuse>
            <specular>1.0 0.0 1.0 1</specular>
        </material>
      </visual>
    </link>

    <link name="rightwheel">
      <pose degrees="true"> -0.23 -0.3 0.35 90 0 0</pose>
      <inertial auto="true">
        <density>400</density>
      </inertial>

      <collision name="collision1">
        <geometry>
            <cylinder>
                <length> 0.1 </length>
                <radius> 0.35 </radius>
            </cylinder>
        </geometry>
      </collision>

      <visual name="visual1">
        <geometry>
            <cylinder>
                <length> 0.1 </length>
                <radius> 0.35 </radius>
            </cylinder>
        </geometry>

        <material>
            <ambient>1.0 0.0 0.0 1</ambient>
            <diffuse>1.0 0.0 0.0 1</diffuse>
            <specular>1.0 0.0 0.0 1</specular>
        </material>
      </visual>
    </link>

    <link name="leftwheel">
      <pose degrees="true"> -0.23 0.3 0.35 90 0 0</pose>
      <inertial auto="true">
        <density>400</density>
      </inertial>

      <collision name="collision1">
        <geometry>
            <cylinder>
                <length> 0.1 </length>
                <radius> 0.35 </radius>
            </cylinder>
        </geometry>
      </collision>

      <visual name="visual1">
        <geometry>
            <cylinder>
                <length> 0.1 </length>
                <radius> 0.35 </radius>
            </cylinder>
        </geometry>

        <material>
            <ambient>0.0 1.0 0.0 1</ambient>
            <diffuse>0.0 1.0 0.0 1</diffuse>
            <specular>0.0 1.0 0.0 1</specular>
        </material>
      </visual>
    </link>

    <link name="ballwheel">
      <pose>0.46 0 0.1 0 0 0</pose>
      <inertial auto="true">
        <density>1500</density>
      </inertial>

      <collision name="collision1">
        <geometry>
            <sphere>
                <radius>0.1</radius>
            </sphere>
        </geometry>
      </collision>

      <visual name="visual1">
        <geometry>
            <sphere>
                <radius>0.1</radius>
            </sphere>
        </geometry>

        <material>
            <ambient>0.0 0.0 1.0 1</ambient>
            <diffuse>0.0 0.0 1.0 1</diffuse>
            <specular>0.0 0.0 1.0 1</specular>
        </material>

      </visual>
    </link>

    <link name="camera">
      <pose degrees="true">0.53 0 0.62 0 30 0</pose>
      <inertial auto="true">
        <density>1000</density>
      </inertial>

      <collision name="collision1">
        <geometry>
            <box>
                <size>0.1 0.1 0.1</size>
            </box>
        </geometry>
      </collision>

      <visual name="visual1">
        <geometry>
            <box>
                <size>0.1 0.1 0.1</size>
            </box>
        </geometry>

        <material>
            <ambient>0.0 1.0 1.0 1</ambient>
            <diffuse>0.0 1.0 1.0 1</diffuse>
            <specular>0.0 1.0 1.0 1</specular>
        </material>
      </visual>

      <sensor name="camera" type="camera">
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>camera</topic>
        </sensor>
    </link>

    <joint name="leftjoint" type="revolute">
        <pose relative_to='leftwheel'/> <!-000省略>
        <parent>body</parent> <!-主要部件>
        <child>leftwheel</child>

        <axis> <!-设置转轴>
            <xyz expressed_in='__model__'>0 1 0</xyz>
            <limit>
                <lower>-1.79769e+308</lower>
                <upper>1.79769e+308</upper>
            </limit>
        </axis> 
    </joint>

    <joint name="rightjoint" type="revolute">
        <pose relative_to='rightwheel'/> <!-000省略>
        <parent>body</parent> <!-主体>
        <child>rightwheel</child>

        <axis> <!-设置转轴>
            <xyz expressed_in='__model__'>0 1 0</xyz>
            <limit>
                <lower>-1.79769e+308</lower>
                <upper>1.79769e+308</upper>
            </limit>
        </axis> 
    </joint>

    <joint name="balljoint" type="ball"> <!-类型不同>
        <pose relative_to='ballwheel'/> <!-相对于小球的关节旋转>
        <parent>body</parent> <!-主要部件>
        <child>ballwheel</child>
    </joint>

    <!-固定>
    <joint name="camerajoint" type="fixed"> <!-类型不同>
        <parent>body</parent> <!-主要部件>
        <child>camera</child>
    </joint>

    <!-使用插件使得小车可以动>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>leftjoint</left_joint>
        <right_joint>rightjoint</right_joint>
        <wheel_separation>0.6</wheel_separation>
        <wheel_radius>0.35</wheel_radius>
        <odom_publish_frequency>1</odom_publish_frequency> <!-里程计发布频率>
        <topic>cmd_vel</topic> <!-控制小车的话题>
    </plugin>
    
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </model>
</sdf>



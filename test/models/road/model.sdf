<?xml version="1.0" ?>
<sdf version="1.11">

  <model name="road">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>50 30</size>
          </plane>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>100</mu>
              <mu2>50</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>50 30</size>
          </plane>
        </geometry>

        <material>
            <diffuse>1.0 1.0 1.0 1</diffuse>
            <specular>0.0 0.0 0.0 1</specular>
            <pbr>
              <metal>
                <albedo_map>road.png</albedo_map>
              </metal>
            </pbr>
        </material>
      </visual>
    </link>

  </model>
</sdf>



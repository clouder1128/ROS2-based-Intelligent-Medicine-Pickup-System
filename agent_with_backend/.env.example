# ==========================
# ROS2 Intelligent Medicine Pickup System
# 环境变量配置
# ==========================

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=*

# --- 数据库配置 ---
# DATABASE_PATH=./pharmacy.db
# DATABASE_URL=sqlite:///./medical_assistant.db

# --- LLM 配置（至少配置一个 API Key） ---
LLM_PROVIDER=openai               
OPENAI_API_KEY=                   
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
ENABLE_STREAMING=false

# --- Agent 配置 ---
MAX_HISTORY_LEN=20
MAX_ITERATIONS=15
SESSION_STATE_DIR=./sessions
PHARMACY_BASE_URL=http://localhost:8001

# --- 并发/异步配置 ---
ENABLE_ASYNC=false
MAX_CONCURRENT_SESSIONS=100
REQUEST_TIMEOUT=30
REQUEST_BATCHING=false
LLM_REQUEST_CACHE_SIZE=50

# --- ROS2 配置 ---
ENABLE_ROS2=true

# --- 症状提取配置 ---
ENABLE_LLM_SYMPTOM_EXTRACTION=true

# --- 日志配置 ---
LOG_LEVEL=INFO

# --- 思考记录配置 ---
ENABLE_THOUGHT_LOGGING=true
THOUGHT_LOG_LEVEL=DETAILED
THOUGHT_LOG_TO_FILE=true
THOUGHT_LOG_TO_CONSOLE=false
THOUGHT_LOG_DIR=./logs/thoughts
THOUGHT_LOG_FORMATS=json,text
THOUGHT_SESSION_AUTO_CLEANUP=true
THOUGHT_SESSION_RETENTION_DAYS=7

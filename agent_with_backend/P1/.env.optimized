# 性能优化配置 - 用于解决LLM响应慢和工作流中断问题
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}  # 使用现有API密钥
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic/v1
LLM_MODEL=deepseek-chat
ANTHROPIC_SMALL_FAST_MODEL=deepseek-chat  # 如果有更快版本则替换
LLM_MAX_TOKENS=2048  # 减少输出长度
LLM_TEMPERATURE=0.2  # 降低随机性，提高响应一致性
REQUEST_TIMEOUT=60   # 增加超时时间，避免超时中断
MAX_ITERATIONS=15    # 增加迭代次数，防止工作流中断
PHARMACY_BASE_URL=http://localhost:8001
LOG_LEVEL=INFO
MAX_HISTORY_LEN=10   # 减少历史消息长度
ENABLE_ASYNC=false   # 暂时关闭异步，避免复杂度
REQUEST_BATCHING=true # 启用请求批处理（需代码支持）
LLM_REQUEST_CACHE_SIZE=50  # LLM请求缓存大小

# 注意：需要设置实际的ANTHROPIC_API_KEY环境变量
# 使用方式：source .env.optimized 或 export $(grep -v '^#' .env.optimized | xargs)